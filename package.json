{
  "name": "@tetherto/miningos-wrk-miner-avalon",
  "version": "0.0.1",
  "description": "MiningOS Worker Miner Avalon",
  "keywords": [
    "tether"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/miningos-wrk-miner-avalon.git"
  },
  "homepage": "https://github.com/tetherto/miningos-wrk-miner-avalon#readme",
  "bugs": {
    "url": "https://github.com/tetherto/miningos-wrk-miner-avalon/issues"
  },  
  "engines": {
    "node": ">=20"
  },
  "files": [
    "worker.js",
    "workers/",
    "mock/"
  ],
  "main": "worker.js",  
  "type": "commonjs",
  "bin": {
    "miningos-wrk-miner-avalon": "worker.js"
  },
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "npm run lint && npm run test:unit && npm run test:integration",
    "test:unit": "brittle tests/unit/*.js",
    "test:integration": "NODE_ENV=test brittle ./tests/miner.test.js",
    "test:coverage": "brittle --coverage tests/{,**/}*.test.js",
    "dev": "node worker.js --wtype=wrk-miner-rack-a1346 --env=production --rack=rack01",
    "mock": "node mock/server.js --type A1346"
  },
  "dependencies": {
    "@bitfinex/bfx-svc-boot-js": "1.2.0",
    "async": "3.2.6",
    "@tetherto/miningos-tpl-wrk-miner": "git+https://github.com/tetherto/miningos-tpl-wrk-miner.git",
    "@tetherto/svc-facs-tcp": "git+https://github.com/tetherto/svc-facs-tcp.git#v1.0.0"
  },
  "devDependencies": {
    "@bitfinex/lib-js-util-base": "git+https://github.com/bitfinexcom/lib-js-util-base.git",
    "@bitfinex/lib-js-util-promise": "git+https://github.com/bitfinexcom/lib-js-util-promise.git",
    "brittle": "3.16.3",
    "debug": "4.4.1",
    "@tetherto/miningos-mock-control-service": "git+https://github.com/tetherto/miningos-mock-control-service.git",
    "standard": "17.1.2",
    "yargs": "17.7.2"
  }
}
